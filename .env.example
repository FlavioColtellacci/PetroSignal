NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared runtime security
CRON_SECRET=replace-with-long-random-secret
BRIEFING_TIMEZONE=America/Caracas

# Firestore admin credentials (Phase 2 Firestore-backed mode)
# Use dev project in local development:
#   FIREBASE_PROJECT_ID=petrosignal-dev
# Use a separate production project in deploy environments:
#   FIREBASE_PROJECT_ID=petrosignal-prod
FIREBASE_PROJECT_ID=petrosignal-dev
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Web SDK (client-side; safe to expose). Used when wiring Firebase Auth.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCf0q9ExdPTdO6yl7dOEQ8WY63WP2IR6Fo
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=petrosignal-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=petrosignal-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=petrosignal-dev.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=723136293160
NEXT_PUBLIC_FIREBASE_APP_ID=1:723136293160:web:12f7f5ee12acb86178c81d

# Provider adapters (currently mock-backed; kept for live provider rollout)
# Search providers for ingestion (sanctions, PDVSA, market, JV tracker, social)
BRAVE_API_KEY=
SERPER_API_KEY=

# MiniMax briefing generation
MINIMAX_API_KEY=
# Model options: MiniMax-M2.7, MiniMax-M2.7-highspeed, MiniMax-M2.5,
# MiniMax-M2.5-highspeed, MiniMax-M2.1, MiniMax-M2.1-highspeed, MiniMax-M2
MINIMAX_MODEL=MiniMax-M2.7-highspeed

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# API rate limits (requests per window)
API_RATE_LIMIT_NEWS_LIMIT=120
API_RATE_LIMIT_NEWS_WINDOW_MS=60000
API_RATE_LIMIT_ALERTS_LIMIT=120
API_RATE_LIMIT_ALERTS_WINDOW_MS=60000
API_RATE_LIMIT_METRICS_LIMIT=120
API_RATE_LIMIT_METRICS_WINDOW_MS=60000
API_RATE_LIMIT_BRIEFING_LIMIT=90
API_RATE_LIMIT_BRIEFING_WINDOW_MS=60000

# Data retention (days). Set 0 or negative to disable collection cleanup.
RETENTION_ARTICLES_DAYS=90
RETENTION_ALERTS_DAYS=120
RETENTION_BRIEFINGS_DAYS=180
RETENTION_AGENT_RUNS_DAYS=30
RETENTION_AUDIT_EVENTS_DAYS=365

# Delivery provider
RESEND_API_KEY=
BRIEFING_FROM_EMAIL=

# Monetization (Phase 2)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
