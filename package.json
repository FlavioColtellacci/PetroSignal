{
  "name": "petrosignal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/ensure-single-next-dev.mjs && NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "dev:clean": "pkill -f \"next dev|next-server\" || true; rm -rf .next",
    "dev:fresh": "npm run dev:clean && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.53.1",
    "ai": "^6.0.175",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "14.2.33",
    "react": "^18",
    "react-dom": "^18",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vercel-minimax-ai-provider": "^0.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.33",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.0.8"
  }
}
